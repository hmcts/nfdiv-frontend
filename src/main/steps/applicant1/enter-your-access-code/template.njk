{% extends "common/page.njk" %}

{% block header %}
  <header class="govuk-template__header">
    {% include "cookie-banner/template.njk" %}
    {{ govukHeader({
      containerClasses: "govuk-width-container"
    }) }}
    {{ govukServiceNavigation({
      serviceName: serviceName,
      serviceUrl: (globals.basePath if globals.basePath) + "/applicant1/enter-your-access-code",
      navigation: [
        {
          href: "/logout" if isLoggedIn else "/login",
          text: signOut if isLoggedIn else signIn
        }
      ]
    }) }}
  </header>
{% endblock %}
