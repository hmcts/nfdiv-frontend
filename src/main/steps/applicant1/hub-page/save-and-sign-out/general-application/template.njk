{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "common/macros/service-address.njk" import serviceAddressMacro %}

{% if hasGenAppSaveAndSignOutContent %}
  <h2 class="govuk-heading-m">{{ generalApplication.heading }}</h2>
  {% if isDraftingWithdraw %}
    <p class="govuk-body">{{ generalApplication.line1Withdraw }}</p>
  {% else %}
    <p class="govuk-body">{{ generalApplication.line1 }}</p>
  {% endif %}

  {% set generalApplicationUpdate %}
    {% if isDraftingWithdraw %}
      <p class="govuk-body">{{ generalApplication.line2Withdraw }}</p>
    {% else %}
      <p class="govuk-body">{{ generalApplication.line2 }}</p>
    {% endif %}
    <p class="govuk-body">{{ generalApplication.line3 }}</p>
    <p class="govuk-body">{{ generalApplication.line4 }}</p>
    {{ govukButton({
      text: generalApplication.continueLinkText,
      href: generalApplication.continueLinkUrl,
      preventDoubleClick: true
    }) }}
    <br />
    {{ govukButton({
      text: generalApplication.withdrawLinkText,
      href: generalApplication.withdrawLinkUrl,
      preventDoubleClick: true,
      classes: 'govuk-button govuk-button--warning'
    }) }}
  {% endset %}

  {{ govukDetails({
    summaryText: generalApplication.continuingTheApplication,
    html: generalApplicationUpdate
  }) }}
{% endif %}