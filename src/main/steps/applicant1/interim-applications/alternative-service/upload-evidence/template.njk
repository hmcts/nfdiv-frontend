{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% extends "common/page.njk" %}

{% block page_content %}
  {{ govukErrorSummary({
    titleText: errorSummaryHeading,
    classes: "hidden",
    attributes: {
      id: "uploadErrorSummary"
    },
    errorList: [
      {
        text: errors.applicant1InterimAppsEvidenceUploadedFiles.errorUploading,
        href: "#upload",
        attributes: {
          id: "errorGeneric",
          class: "hidden"
        }
      },
      {
        text: errors.applicant1InterimAppsEvidenceUploadedFiles.fileSizeTooBig,
        href: "#upload",
        attributes: {
          id: "errorFileSizeTooBig",
          class: "hidden"
        }
      },
      {
        text: errors.applicant1InterimAppsEvidenceUploadedFiles.fileWrongFormat,
        href: "#upload",
        attributes: {
          id: "errorFileWrongFormat",
          class: "hidden"
        }
      }
    ]
  }) }}

  <h1 class="govuk-heading-l" id="uploadEvidenceTitle">{{ title }}</h1>
  <p class="govuk-body">{{ statement }}</p>
  <p class="govuk-body">{{ certifiedTranslation | safe }}</p>
  <p class="govuk-body">{{ toInclude.header }}</p>
  <ul class="govuk-list govuk-list--bullet">
    <li>{{ toInclude.options.partnersName }}</li>
    <li>{{ toInclude.options.dateMessageSent }}</li>
    {% if methodSelected == 'byEmail' or methodSelected == 'emailAndDifferentWay' %}
      <li>{{ toInclude.options.partnersEmailInfo }}</li>
    {% endif %}
    {% if 'textMessage' in waysSelectedForDifferent or 'whatsapp' in waysSelectedForDifferent %}
      <li>{{ toInclude.options.partnersPhoneInfo }}</li>
    {% endif %}
    {% if 'socialMedia' in waysSelectedForDifferent %}
          <li>{{ toInclude.options.partnersSocialMediaUsernameInfo }}</li>
    {% endif %}
  </ul>
  <p class="govuk-body">{{ line4 }}</p>
  <p class="govuk-body">{{ line5 }}</p>
  <p class="govuk-body">{{ evidenceDateReminder }}</p>

{% endblock %}

{% block form %}
  {% include "../../common/upload-evidence/form.njk" %}
{% endblock %}
